# Main configuration file for Bank Fraud Detection Solution

## Database Configuration
DATABASE_URL=postgresql://fraud_user:fraud_password@localhost:5432/fraud_detection_db

## MongoDB Configuration  
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=fraud_detection

## Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTION_TOPIC=transactions
KAFKA_ALERT_TOPIC=fraud_alerts
KAFKA_RESULT_TOPIC=fraud_detection_results
KAFKA_GROUP_ID=fraud-detection-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

## API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_LOG_LEVEL=INFO

## ML Model Configuration
TRANSACTION_MODEL_PATH=models/transaction_anomaly_detector.pkl
MULE_ACCOUNT_MODEL_PATH=models/mule_account_detector.pkl
FRAUD_SCORE_THRESHOLD=0.5
MULE_SCORE_THRESHOLD=0.6

## Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8001
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

## Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/fraud_detection.log

## Security
JWT_SECRET_KEY=your-secret-key-here
API_KEY_REQUIRED=true

## Data Validation
ENABLE_STRICT_VALIDATION=true
MAX_TRANSACTION_AMOUNT=999999999
MIN_TRANSACTION_AMOUNT=0

## Alert Configuration
ALERT_EMAIL_ENABLED=false
ALERT_SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

## Feature Engineering
ENABLE_FEATURE_CACHING=true
CACHE_EXPIRY_HOURS=24

## Performance
MAX_BATCH_SIZE=1000
PROCESSING_TIMEOUT_SECONDS=30
CONNECTION_POOL_SIZE=20
